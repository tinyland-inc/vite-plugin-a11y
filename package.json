{
  "name": "@tinyland/vite-plugin-a11y",
  "version": "1.0.0",
  "description": "Vite plugin for accessibility validation of Svelte components - WCAG compliance checking at build time",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "accessibility",
    "a11y",
    "wcag",
    "svelte",
    "contrast",
    "aria",
    "validation"
  ],
  "author": "Tinyland.dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/tinyland/tinyland.dev"
  },
  "dependencies": {
    "magic-string": "^0.30.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "svelte": "^5.0.0",
    "typescript": "^5.0.0",
    "vite": "^7.0.0",
    "vitest": "^4.0.0"
  },
  "peerDependencies": {
    "svelte": "^4.0.0 || ^5.0.0",
    "vite": "^5.0.0 || ^6.0.0 || ^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
